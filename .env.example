# OpenClaw Empathy Anchor — local demo environment
# Copy to .env and adjust. Never commit real secrets.

# Backend
PORT=8000
OFFLINE_MODE=true
DEBUG=false
FLASK_ENV=development
DEMO_AUTH=true

# Required for FLASK_ENV=production. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=local-demo-only-not-for-production

# Local SQLite alert store
ALERT_DB_PATH=./data/alerts.db

# Comma-separated browser origins allowed by CORS
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional external model keys (not required — offline-first by default)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
