# Backend local demo environment
JWT_SECRET_KEY=local-demo-only-not-for-production
OFFLINE_MODE=true
DEBUG=false
PORT=8000
DEMO_AUTH=true
ALERT_DB_PATH=../data/alerts.db
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Production only — never use demo secrets:
# FLASK_ENV=production
# DEMO_AUTH=false
# JWT_SECRET_KEY=<64-char hex from secrets.token_hex(32)>
