# MindMend Super AI Backend - Environment Variables
# Copy this file to .env and update with your values

# Flask Configuration
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
OFFLINE_MODE=true
DEBUG=false
PORT=8000

# Demo authentication (issues JWT for any user_id — NOT production auth)
DEMO_AUTH=true

# Production mode — requires a real JWT_SECRET_KEY; disables demo login unless DEMO_AUTH=true
# FLASK_ENV=production

# Local SQLite alert storage (privacy-first, offline-safe)
ALERT_DB_PATH=../data/alerts.db

# Logging
LOG_LEVEL=INFO

# Security
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET_KEY=your-64-character-hex-string-here
